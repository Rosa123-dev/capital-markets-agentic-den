<div class="toast" id="toast"><span class="toast-accent" id="toastMsg"></span></div>

<script>
  window.addEventListener('scroll', () => {
    document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 20);
  });

  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(el => io.observe(el));

  // Particles
  const grad = document.getElementById('heroGradient');
  for (let i = 0; i < 14; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    const s = 4 + Math.random() * 12;
    p.style.cssText = `width:${s}px;height:${s}px;left:${Math.random()*100}%;bottom:${Math.random()*40}px;animation-duration:${6+Math.random()*8}s;animation-delay:${Math.random()*6}s`;
    grad.appendChild(p);
  }

  // Toggle agents
  function toggleAgent(id) {
    const card = document.getElementById(id);
    card.classList.toggle('open');
  }

  // Copy prompt
  function copyPrompt(btn) {
    const text = btn.parentElement.querySelector('.prompt-text').innerText;
    navigator.clipboard.writeText(text).then(() => showToast('✓ Prompt copied to clipboard'));
  }

  // Checklist
  function toggleCheck(card) {
    card.classList.toggle('checked');
    const total = document.querySelectorAll('.cl-card').length;
    const done = document.querySelectorAll('.cl-card.checked').length;
    document.getElementById('progressFill').style.width = (done / total * 100) + '%';
    document.getElementById('progressCount').textContent = done;
    if (done === total) showToast('✓ All checks complete — you\'re ready to deploy!');
  }

  function showToast(msg) {
    document.getElementById('toastMsg').textContent = msg;
    const t = document.getElementById('toast');
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3000);
  }
</script>
